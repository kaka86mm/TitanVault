# presets/standard.env
# 标准档: 在 minimal 基础上加 AI 能力 (ASR/TTS/PDF解析/MCP) + 网络 (代理/穿透)。
# 对应 compose profiles: infra + gateway + ai-capability + network
INCLUDE_INFRA=true
INCLUDE_GATEWAY=true
INCLUDE_AI_CAPABILITY=true
INCLUDE_NETWORK=true
INCLUDE_APPS=false
INCLUDE_MONITORING=false
INCLUDE_AGENTS=false
