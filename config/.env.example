# config/.env.example
# TitanVault 环境配置模板
#
# 用法: cp config/.env.example .env  然后填值; 或直接跑 install.sh 自动生成。
# 安装器读每行变量的 @标记 注释决定如何处理:
#   @auto-generate  → 安装器用 openssl rand -hex 随机生成 (用户无需填)
#   @user-input     → 交互式询问 (空值=用默认或留空)
#   @default:XXX    → 未设置时用 XXX
#   @optional       → 可留空, 不影响核心功能

# ============ 全局 ============
# @required @user-input 部署用户 (systemd 服务以此用户运行 llama.cpp)
DEPLOY_USER=
# @required @user-input 数据根目录 (所有服务卷挂在此下)
DATA_DIR=/data
# @required @user-input 模型下载源: modelscope (国内快) / hf (全球)
MODEL_SOURCE=modelscope
# @optional @default:https://docker.1ms.run,https://docker.xuanyuan.me,https://docker.m.daocloud.io docker 镜像源 (逗号分隔, 仅 MODEL_SOURCE=modelscope 时自动配置; 留空跳过; 已配置则不覆盖)
DOCKER_MIRRORS=https://docker.1ms.run,https://docker.xuanyuan.me,https://docker.m.daocloud.io
# @optional @default:standard 安装档位: minimal / standard / full
PRESET=standard
# @optional @user-input 宿主机对外 IP (Open Notebook 等回调用, 留空则用 hostname -I)
HOST_IP=
# @optional @default:127.0.0.1 LiteLLM 绑定 (127.0.0.1=仅本机; 0.0.0.0 或空=放开到局域网/多子网)
LITELLM_BIND=127.0.0.1

# ============ 运维 (ops.sh 定时任务) ============
# 调度表达式 (留空=不调度该项); 安装: bash scripts/setup-cron.sh
# ⚠ cron 表达式含空格, 必须加引号 (load_env 用 source 执行 .env, 不加引号会报 'command not found')
# @optional @default:0 3 * * * 每天备份时间
OPS_BACKUP_CRON="0 3 * * *"
# @optional @default:0 4 * * * 每天自愈+清理时间
OPS_HEAL_CRON="0 4 * * *"
# @optional @default:0 5 * * 0 每周镜像更新时间 (--yes 会自动重建)
OPS_UPDATE_CRON="0 5 * * 0"
# @optional @default:7 备份保留天数
OPS_BACKUP_RETENTION_DAYS=7
# @optional @default:true 健康检查检测到critical是否自动自愈 (false=只记录不自愈)
OPS_AUTO_HEAL=true
# @optional @user-input uptime-kuma API地址 (注册监控用, 留空跳过)
UPTIME_KUMA_URL=http://localhost:3001
# @optional @user-input uptime-kuma API token (设置→API Keys生成, 留空则打印手动清单)
UPTIME_KUMA_TOKEN=

# ============ 密码 (安装器 @auto-generate, 无需手填) ============
# @required @auto-generate PostgreSQL 主密码 (infra 层共享)
POSTGRES_PASSWORD=
# @required @auto-generate Redis 密码
REDIS_PASSWORD=
# @required @auto-generate LiteLLM master key (LLM 路由鉴权)
LITELLM_MASTER_KEY=
# @required @auto-generate Qdrant 向量库 API key (向量检索鉴权)
QDRANT_API_KEY=
# @required @auto-generate Hermes API server key
HERMES_API_SERVER_KEY=
# @required @auto-generate Open Notebook SurrealDB 密码
OPEN_NOTEBOOK_SURREAL_PASSWORD=
# @required @auto-generate Open Notebook 加密密钥
OPEN_NOTEBOOK_ENCRYPTION_KEY=

# ============ 硬件 ============
# @optional @default:aimax-395 硬件 profile (见 hardware/*.profile)
HARDWARE_PROFILE=aimax-395

# ============ 模型 (硬件 profile 覆盖, 一般不手改) ============
# @optional @default:Qwen3.6-35B-A3B 主力 LLM 模型名
LLM_MODEL_NAME=Qwen3.6-35B-A3B
# @optional @default:Qwen3-Embedding-0.6B Embedding 模型名
EMBED_MODEL_NAME=Qwen3-Embedding-0.6B

# ============ aham-voice-web (录音转写 + 会议纪要) ============
# @optional @user-input aham-voice-web 访问密码 (留空=局域网默认开放, 与发行版其它服务风格一致)
AHAMVOICE_ACCESS_PASSWORD=

# ============ MinerU Web (PDF 解析) ============
# @optional @default:high MinerU 解析精度 (high=高精度含图表, medium=更快)
MINERU_API_HYBRID_EFFORT=high
# @optional @default:1 解析 worker 并发数 (395 建议 1, 显存/内存有限)
MINERU_WORKER_CONCURRENCY=1
# @optional @user-input MinerU MinIO 管理员用户名 (默认 minioadmin, 生产建议改)
MINERU_MINIO_ROOT_USER=minioadmin
# @optional @user-input MinerU MinIO 管理员密码 (默认 minioadmin, 生产建议改)
MINERU_MINIO_ROOT_PASSWORD=minioadmin

# ============ 代理 / 内网穿透 (空配纳入发行版, 用户按需填) ============
# @optional @user-input mihomo 订阅链接 (留空=直连模式, 不启用代理)
MIHOMO_SUBSCRIBE_URL=
# @optional @user-input frp 服务器地址 (留空=不启用内网穿透)
FRP_SERVER_ADDR=
# @optional @user-input frp 鉴权 token
FRP_TOKEN=
